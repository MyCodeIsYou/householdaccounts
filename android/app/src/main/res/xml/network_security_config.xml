<?xml version="1.0" encoding="utf-8"?>
<!--
  HTTPS 강제. cleartext(HTTP) 트래픽 전면 차단.
  가계부 앱은 Supabase HTTPS API만 사용하므로 안전.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
