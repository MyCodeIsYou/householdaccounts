<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 11 이하(API 30-) full-backup 규칙.
  민감한 인증 데이터는 모두 제외.
-->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
    <exclude domain="file" />
</full-backup-content>
