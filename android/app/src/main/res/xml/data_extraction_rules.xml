<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) 데이터 추출 규칙.
  가계부 앱 특성상 인증 토큰/캐시/DB는 백업 및 D2D 이전에서 모두 제외.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
